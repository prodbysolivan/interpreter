{
  "name": "@prodbysolivan/interpreter",
  "description": "Type-safe framework for building robust command-line applications.",
  "version": "2.0.1",
  "exports": "./source/index.ts",
  "publish": {
    "include": ["source/**/*.ts", "deno.json", "README.md", "LICENSE"]
  },
  "tasks": {
    "format": "deno fmt",
    "lint": "deno lint",
    "clean": "rm -rf build"
  },
  "imports": {
    "@prodbysolivan/match": "jsr:@prodbysolivan/match@^2.0.0",
    "@prodbysolivan/option": "jsr:@prodbysolivan/option@^1.0.0",
    "@prodbysolivan/result": "jsr:@prodbysolivan/result@^1.0.0",
    "@prodbysolivan/signal": "jsr:@prodbysolivan/signal@^1.3.0",
    "@prodbysolivan/types": "jsr:@prodbysolivan/types@^1.0.2",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  }
}
